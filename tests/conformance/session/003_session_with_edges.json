{
  "name": "session_with_edges",
  "description": "Session dedup preserves edges even when symbols are bare refs",
  "calls": [
    {
      "input": {
        "tool": "test",
        "tokenBudget": 5000,
        "tokensUsed": 200,
        "packRoot": "",
        "symbols": [
          {"qualifiedName": "pkg.Auth", "kind": "function", "score": 0.90, "provenance": "lsp", "distance": 0},
          {"qualifiedName": "pkg.Server", "kind": "function", "score": 0.60, "provenance": "lsp", "distance": 1}
        ],
        "edges": [
          {"source": "pkg.Server", "target": "pkg.Auth", "edgeType": "calls", "status": ""}
        ]
      },
      "expected": "GCF tool=test budget=5000 tokens=200 symbols=2 session=true\n## targets\n@0 fn pkg.Auth 0.90 lsp\n## related\n@1 fn pkg.Server 0.60 lsp\n## edges\n@0<@1 calls\n"
    },
    {
      "input": {
        "tool": "test",
        "tokenBudget": 5000,
        "tokensUsed": 100,
        "packRoot": "",
        "symbols": [
          {"qualifiedName": "pkg.Auth", "kind": "function", "score": 0.90, "provenance": "lsp", "distance": 0},
          {"qualifiedName": "pkg.Server", "kind": "function", "score": 0.60, "provenance": "lsp", "distance": 1},
          {"qualifiedName": "pkg.Config", "kind": "type", "score": 0.40, "provenance": "ast", "distance": 2}
        ],
        "edges": [
          {"source": "pkg.Server", "target": "pkg.Auth", "edgeType": "calls", "status": ""},
          {"source": "pkg.Auth", "target": "pkg.Config", "edgeType": "references", "status": ""}
        ]
      },
      "expected": "GCF tool=test budget=5000 tokens=100 symbols=3 session=true\n## targets\n@0  # previously transmitted\n## related\n@1  # previously transmitted\n## extended\n@2 type pkg.Config 0.40 ast\n## edges\n@0<@1 calls\n@2<@0 references\n"
    }
  ]
}
