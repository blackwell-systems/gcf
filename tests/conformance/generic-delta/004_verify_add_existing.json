{
  "name": "generic_delta_verify_add_existing",
  "description": "An `## added` row whose identity already exists in the base is a contradictory operation and MUST be rejected (Section 10a.5). base_root is valid, so validation reaches the add-existing check.",
  "operation": "generic-delta-verify",
  "input": {
    "base": {
      "key": "id",
      "fields": ["id", "total", "status", "customer"],
      "rows": [
        {"id": 1001, "total": 59.98, "status": "shipped", "customer": "Alice"},
        {"id": 1002, "total": 29.99, "status": "pending", "customer": "Bob"},
        {"id": 1003, "total": 129.50, "status": "shipped", "customer": "Carol"}
      ]
    },
    "delta": {
      "key": "id",
      "fields": ["id", "total", "status", "customer"],
      "baseRoot": "sha256:457e7c31e62e070a039b5cde9ea3edff6330e5913874e1165afddbcf6798eb7c",
      "added": [{"id": 1001, "total": 10.00, "status": "new", "customer": "Zed"}]
    },
    "expectedNewRoot": "sha256:unused"
  },
  "expectedError": "already exists"
}
